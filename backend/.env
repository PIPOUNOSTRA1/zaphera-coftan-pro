# Server configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=*

# Google Sheets Configuration
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
GOOGLE_SPREADSHEET_ID=your-google-spreadsheet-id

# Tracking Configurations (Meta Pixel / Conversions API)
META_PIXEL_ID=your-meta-pixel-id
META_ACCESS_TOKEN=your-meta-capi-access-token

# TikTok Pixel & Events API
TIKTOK_PIXEL_ID=your-tiktok-pixel-id
TIKTOK_ACCESS_TOKEN=your-tiktok-events-api-access-token

# Snapchat Pixel & Conversions API
SNAP_PIXEL_ID=your-snap-pixel-id
SNAP_ACCESS_TOKEN=your-snap-capi-access-token
